renders optional deployment and service fields:
  1: |
    apiVersion: apps/v1
    kind: Deployment
    metadata:
      labels:
        app.kubernetes.io/instance: unit
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: pxc-operator
        app.kubernetes.io/version: 1.20.0
        helm.sh/chart: pxc-operator-1.20.0
      name: unit-pxc-operator
      namespace: test-ns
    spec:
      replicas: 1
      selector:
        matchLabels:
          app.kubernetes.io/component: operator
          app.kubernetes.io/instance: unit
          app.kubernetes.io/name: pxc-operator
          app.kubernetes.io/part-of: pxc-operator
      strategy:
        rollingUpdate:
          maxUnavailable: 1
        type: RollingUpdate
      template:
        metadata:
          annotations:
            test: value
          labels:
            app.kubernetes.io/component: operator
            app.kubernetes.io/instance: unit
            app.kubernetes.io/name: pxc-operator
            app.kubernetes.io/part-of: pxc-operator
        spec:
          containers:
            - command:
                - percona-xtradb-cluster-operator
              env:
                - name: WATCH_NAMESPACE
                  value: ""
                - name: POD_NAME
                  valueFrom:
                    fieldRef:
                      fieldPath: metadata.name
                - name: OPERATOR_NAME
                  value: unit-pxc-operator
                - name: LOG_STRUCTURED
                  value: "false"
                - name: LOG_LEVEL
                  value: INFO
                - name: DISABLE_TELEMETRY
                  value: "false"
                - name: MAX_CONCURRENT_RECONCILES
                  value: "1"
                - name: S3_WORKERS_LIMIT
                  value: "10"
                - name: PXCO_FEATURE_GATES
                  value: XtrabackupSidecar=false
                - name: EXTRA_FLAG
                  value: enabled
              image: custom-operator:9.9.9
              imagePullPolicy: IfNotPresent
              livenessProbe:
                failureThreshold: 3
                httpGet:
                  path: /metrics
                  port: metrics
                  scheme: HTTP
              name: percona-xtradb-cluster-operator
              ports:
                - containerPort: 8080
                  name: metrics
                  protocol: TCP
              resources:
                limits:
                  cpu: 200m
                  memory: 500Mi
                requests:
                  cpu: 100m
                  memory: 20Mi
              securityContext:
                allowPrivilegeEscalation: false
                readOnlyRootFilesystem: true
              volumeMounts:
                - mountPath: /tmp
                  name: tmpdir
          imagePullSecrets:
            - name: registry-secret
          serviceAccountName: unit-pxc-operator
          terminationGracePeriodSeconds: 600
          volumes:
            - emptyDir: {}
              name: tmpdir
  2: |
    apiVersion: v1
    kind: Service
    metadata:
      labels:
        name: percona-xtradb-cluster-operator
      name: percona-xtradb-cluster-operator
      namespace: test-ns
    spec:
      ports:
        - port: 443
          targetPort: 9443
      selector:
        app.kubernetes.io/name: pxc-operator
renders the default operator deployment:
  1: |
    apiVersion: apps/v1
    kind: Deployment
    metadata:
      labels:
        app.kubernetes.io/instance: unit
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: pxc-operator
        app.kubernetes.io/version: 1.20.0
        helm.sh/chart: pxc-operator-1.20.0
      name: unit-pxc-operator
      namespace: test-ns
    spec:
      replicas: 1
      selector:
        matchLabels:
          app.kubernetes.io/component: operator
          app.kubernetes.io/instance: unit
          app.kubernetes.io/name: pxc-operator
          app.kubernetes.io/part-of: pxc-operator
      strategy:
        rollingUpdate:
          maxUnavailable: 1
        type: RollingUpdate
      template:
        metadata:
          labels:
            app.kubernetes.io/component: operator
            app.kubernetes.io/instance: unit
            app.kubernetes.io/name: pxc-operator
            app.kubernetes.io/part-of: pxc-operator
        spec:
          containers:
            - command:
                - percona-xtradb-cluster-operator
              env:
                - name: WATCH_NAMESPACE
                  value: test-ns
                - name: POD_NAME
                  valueFrom:
                    fieldRef:
                      fieldPath: metadata.name
                - name: OPERATOR_NAME
                  value: unit-pxc-operator
                - name: LOG_STRUCTURED
                  value: "false"
                - name: LOG_LEVEL
                  value: INFO
                - name: DISABLE_TELEMETRY
                  value: "false"
                - name: MAX_CONCURRENT_RECONCILES
                  value: "1"
                - name: S3_WORKERS_LIMIT
                  value: "10"
                - name: PXCO_FEATURE_GATES
                  value: XtrabackupSidecar=false
              image: percona/percona-xtradb-cluster-operator:1.20.0
              imagePullPolicy: IfNotPresent
              livenessProbe:
                failureThreshold: 3
                httpGet:
                  path: /metrics
                  port: metrics
                  scheme: HTTP
              name: percona-xtradb-cluster-operator
              ports:
                - containerPort: 8080
                  name: metrics
                  protocol: TCP
              resources:
                limits:
                  cpu: 200m
                  memory: 500Mi
                requests:
                  cpu: 100m
                  memory: 20Mi
          serviceAccountName: unit-pxc-operator
          terminationGracePeriodSeconds: 600
